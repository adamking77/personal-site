---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import { articleGraph, SITE_URL } from '../../utils/schema/index';

export async function getStaticPaths() {
  const posts = await getCollection('writing');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
const hasToc = tocHeadings.length >= 3;

const postUrl = `${SITE_URL}/writing/${post.id}/`;
const ogImage = `${SITE_URL}/og/${post.id}.jpg`;
const graph = articleGraph({
  url: postUrl,
  title: post.data.title,
  description: post.data.description,
  datePublished: post.data.date,
  category: post.data.category,
  ogImage,
});
---

<Layout
  title={`${post.data.title} — Adam King`}
  description={post.data.description}
  ogType="article"
  ogImage={ogImage}
  ogImageAlt={post.data.title}
  article={{
    publishedTime: post.data.date.toISOString(),
    section: post.data.category ?? 'Resource',
  }}
  graph={graph}
>
  <Navigation />
  <main class="w-full relative z-10 pt-24 md:pt-32">

    <!-- Post header -->
    <header class="px-6 w-full max-w-6xl mx-auto py-16 md:py-20 post-header opacity-0">

      <!-- Breadcrumb -->
      <div class="mb-12">
        <a href="/writing/" class="font-mono text-[11px] tracking-[0.2em] uppercase text-theme-muted hover:text-theme transition-colors duration-200">
          ← Writing
        </a>
      </div>

      <!-- Meta row -->
      <div class="flex items-center gap-5 mb-10">
        <span class="font-mono text-[11px] tracking-[0.2em] uppercase text-accent">
          {post.data.category ?? 'Resource'}
        </span>
      </div>

      <!-- Title -->
      <h1 class="font-sans font-light text-[2rem] md:text-[2.75rem] lg:text-[3.5rem] leading-[1.1] tracking-[-0.03em] text-theme max-w-4xl mb-8" style="font-optical-sizing: auto;">
        {post.data.title}
      </h1>

      <!-- Description lede -->
      <p class="font-sans font-light text-[1.1rem] md:text-[1.25rem] leading-[1.6] tracking-[-0.01em] text-theme-muted max-w-2xl">
        {post.data.description}
      </p>

      <!-- Divider -->
      <div class="mt-12 w-full h-px post-rule" style="background-color: var(--border-color); transform-origin: left center; transform: scaleX(0);"></div>

    </header>

    <!-- Post body -->
    <article class="px-6 w-full max-w-6xl mx-auto pb-24 md:pb-32 post-body opacity-0">
      <div class={hasToc ? "lg:flex lg:gap-16" : ""}>

        {hasToc && (
          <aside class="article-sidebar hidden lg:block shrink-0">
            <nav class="article-toc" style="position: sticky; top: 7rem;">
              <span class="toc-eyebrow">Contents</span>
              <ul class="toc-list">
                {tocHeadings.map((h) => (
                  <li class={`toc-item toc-depth-${h.depth}`}>
                    <a href={`#${h.slug}`} class="toc-link" data-heading-id={h.slug}>
                      {h.text}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </aside>
        )}

        <div class={`prose ${hasToc ? 'max-w-[68ch] w-full min-w-0' : 'lg:ml-[20%] max-w-[68ch]'}`}>
          <Content />
        </div>

      </div>
    </article>

  </main>
  <Footer />

  <!-- Ambient glow -->
  <div class="fixed top-0 left-0 w-full h-screen pointer-events-none z-0 overflow-hidden flex justify-center items-center opacity-25 dark:opacity-20">
    <div class="absolute w-[500px] h-[500px] rounded-full blur-[140px]" style="background-color: color-mix(in srgb, var(--accent) 15%, transparent);"></div>
  </div>
</Layout>

<style>
  .article-sidebar {
    width: 18%;
  }

  .toc-eyebrow {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.65em;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.1em;
  }

  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-left: 1px solid var(--border-color);
  }

  .toc-link {
    display: block;
    padding: 0.38em 0.9em;
    font-size: 0.73rem;
    font-weight: 300;
    color: var(--text-muted);
    text-decoration: none;
    line-height: 1.45;
    transition: color 0.15s ease, border-color 0.15s ease;
    border-left: 2px solid transparent;
    margin-left: -1px;
  }

  .toc-link:hover {
    color: var(--text-color);
  }

  .toc-depth-3 .toc-link {
    padding-left: 1.5em;
    font-size: 0.68rem;
  }

  .toc-link.is-active {
    color: var(--accent);
    border-left-color: var(--accent);
    opacity: 1;
  }
</style>

<script>
  import gsap from 'gsap';

  window.addEventListener('DOMContentLoaded', () => {
    const tl = gsap.timeline({ delay: 0.1 });
    tl.to('.post-header', { opacity: 1, duration: 0.8, ease: 'power3.out' })
      .to('.post-rule', { scaleX: 1, duration: 1.1, ease: 'power3.inOut' }, '-=0.4')
      .to('.post-body', { opacity: 1, duration: 0.8, ease: 'power3.out' }, '-=0.6');

    // TOC active section tracking
    const headingEls = Array.from(document.querySelectorAll('article h2[id], article h3[id]'));
    const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('.toc-link'));

    if (headingEls.length && tocLinks.length) {
      const onScroll = () => {
        let current = (headingEls[0] as HTMLElement).id;

        for (const el of headingEls as HTMLElement[]) {
          if (el.getBoundingClientRect().top < 140) {
            current = el.id;
          }
        }

        tocLinks.forEach(link => {
          link.classList.toggle('is-active', link.dataset.headingId === current);
        });
      };

      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }
  });
</script>

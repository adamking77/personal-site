---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import { writingListGraph } from '../../utils/schema/index';

const posts = (await getCollection('writing')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const graph = writingListGraph();
---

<Layout
  title="Writing — Adam King on Counter-Exploitation"
  description="Writing on counter-exploitation, autonomy restoration, agentic partnership design, and the generalized specialist practice."
  graph={graph}
>
  <Navigation />
  <main class="w-full relative z-10 pt-24 md:pt-32">

    <section class="px-6 w-full max-w-6xl mx-auto py-16 md:py-24">

      <!-- Section label -->
      <div class="flex items-center gap-5 mb-16 md:mb-20 writing-label opacity-0">
        <h1 class="font-mono text-[17px] tracking-[0.18em] uppercase text-theme-muted whitespace-nowrap">Writing</h1>
        <div class="writing-rule flex-1 h-px" style="background-color: var(--border-color); transform-origin: left center; transform: scaleX(0);"></div>
      </div>

      <!-- Post list -->
      <div>
        {posts.map((post, i) => (
          <a
            href={`/writing/${post.id}/`}
            class="writing-item opacity-0 grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-3 lg:gap-16 py-9 block group"
            style="border-bottom: 1px solid var(--border-color);"
          >
            <div class="flex items-start gap-5">
              <span class="font-mono text-[11px] tracking-[0.2em] uppercase text-accent">
                {String(i + 1).padStart(2, '0')}
              </span>
              <span class="font-mono text-[11px] tracking-[0.2em] uppercase text-theme-muted">
                {post.data.category ?? 'Resource'}
              </span>
            </div>
            <div>
              <h2 class="font-sans font-light text-[1.6rem] md:text-[2rem] leading-[1.2] tracking-[-0.025em] text-theme mb-4 group-hover:text-accent transition-colors duration-300" style="font-optical-sizing: auto;">
                {post.data.title}
              </h2>
              <p class="text-[0.95rem] md:text-base font-light leading-[1.75] text-theme-muted max-w-lg">
                {post.data.description}
              </p>
              <span class="inline-block mt-5 font-mono text-[11px] tracking-[0.2em] uppercase text-accent group-hover:tracking-[0.3em] transition-all duration-300">
                Read →
              </span>
            </div>
          </a>
        ))}
      </div>

    </section>

  </main>
  <Footer />

  <!-- Ambient glow -->
  <div class="fixed top-0 left-0 w-full h-screen pointer-events-none z-0 overflow-hidden flex justify-center items-center opacity-25 dark:opacity-20">
    <div class="absolute w-[500px] h-[500px] rounded-full blur-[140px]" style="background-color: color-mix(in srgb, var(--accent) 15%, transparent);"></div>
  </div>
</Layout>

<script>
  import gsap from 'gsap';

  window.addEventListener('DOMContentLoaded', () => {
    const labelTl = gsap.timeline({ delay: 0.2 });
    labelTl
      .to('.writing-label', { opacity: 1, duration: 0.6, ease: 'power3.out' })
      .to('.writing-rule', { scaleX: 1, duration: 1.1, ease: 'power3.inOut' }, '-=0.3');

    const items = gsap.utils.toArray('.writing-item') as HTMLElement[];
    items.forEach((el, i) => {
      gsap.fromTo(el,
        { opacity: 0, y: 28 },
        { opacity: 1, y: 0, duration: 0.9, ease: 'power3.out', delay: 0.4 + i * 0.1 }
      );
    });
  });
</script>

---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import FuzzyRedirect from '@jdevalk/astro-seo-graph/FuzzyRedirect.astro';
---

<Layout title="404: Page Not Found — Adam King" description="The page you're looking for doesn't exist or has moved. Head back to the homepage." noindex={true}>
  <Navigation />
  <main class="w-full relative z-10 pt-24 md:pt-32">
    <section class="px-6 w-full max-w-6xl mx-auto py-32 md:py-48">

      <div class="mb-8">
        <span class="font-mono text-[11px] tracking-[0.2em] uppercase text-accent">404</span>
      </div>

      <h1 class="font-sans font-light text-[2.5rem] md:text-[3.5rem] leading-[1.1] tracking-[-0.03em] text-theme mb-6" style="font-optical-sizing: auto;">
        Page not found
      </h1>

      <p class="font-sans font-light text-[1.1rem] leading-[1.6] text-theme-muted max-w-xl mb-12">
        The page you're looking for doesn't exist or has moved.
      </p>

      <a href="/" class="font-mono text-[11px] tracking-[0.2em] uppercase text-accent hover:text-theme transition-colors duration-200">
        ← Back to home
      </a>

    </section>
  </main>
  <Footer />

  <FuzzyRedirect />
</Layout>

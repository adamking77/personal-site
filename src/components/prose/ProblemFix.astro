---
interface Item {
  problem: string;
  fix: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<div class="problem-fix">
  {items.map((item) => (
    <div class="row">
      <div class="problem">
        <span class="col-label">Mistake</span>
        {item.problem}
      </div>
      <div class="fix">
        <span class="col-label">Fix</span>
        {item.fix}
      </div>
    </div>
  ))}
</div>

<style>
  .problem-fix {
    display: flex;
    flex-direction: column;
    gap: 1px;
    margin: 2em 0;
    background-color: var(--border-color);
    border: 1px solid var(--border-color);
  }
  .row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background-color: var(--border-color);
  }
  .problem, .fix {
    background-color: var(--bg-color);
    padding: 1.25em;
    font-size: 0.875em;
    line-height: 1.5;
    font-weight: 300;
  }
  .problem {
    color: var(--text-color);
    font-weight: 400;
  }
  .fix {
    color: var(--text-muted);
  }
  .col-label {
    display: none;
  }
  @media (max-width: 640px) {
    .row {
      grid-template-columns: 1fr;
    }
    .col-label {
      display: block;
      font-family: var(--font-mono);
      font-size: 0.7em;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.4em;
    }
  }
</style>

---
interface Props {
  label?: string;
}

const { label = "How we do it at GenZen" } = Astro.props;
---

<aside class="callout">
  <span class="callout-label">{label}</span>
  <div class="callout-content">
    <slot />
  </div>
</aside>

<style>
  .callout {
    border: 1px solid var(--border-color);
    background-color: color-mix(in srgb, var(--accent) 4%, transparent);
    padding: 2em 2em;
    margin: 2.5em 0;
  }
  .callout-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.7em;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.25em;
  }
  .callout-content {
    color: var(--text-color);
    font-size: 1em;
    line-height: 1.75;
    font-weight: 300;
  }
  .callout-content :global(p) {
    margin-bottom: 1em;
  }
  .callout-content :global(p:last-child) {
    margin-bottom: 0;
  }
  .callout-content :global(ul) {
    list-style: none;
    padding: 0;
    margin: 1em 0;
  }
  .callout-content :global(li) {
    padding-left: 1.25em;
    position: relative;
    margin-bottom: 0.4em;
  }
  .callout-content :global(li::before) {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.8em;
  }
  .callout-content :global(strong) {
    font-weight: 500;
    color: var(--text-color);
  }
  .callout-content :global(em) {
    font-style: italic;
  }
  .callout-content :global(pre) {
    background-color: color-mix(in srgb, var(--text-color) 5%, transparent);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    padding: 1.25em 1.5em;
    overflow-x: auto;
    margin: 1em 0;
  }
  .callout-content :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.875rem;
    line-height: 1.7;
    font-family: var(--font-mono);
  }
  .callout-content :global(code:not(pre code)) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background-color: color-mix(in srgb, var(--text-color) 6%, transparent);
    padding: 0.15em 0.4em;
    border-radius: 3px;
  }
</style>
